LIBRA_INTERVIEW_API_KEY=replace-with-your-libra-api-key
LIBRA_BASE_URL=https://replace-with-your-libra-endpoint.example/api/projects/replace-with-project/openai/v1

# Optional runtime settings
SALES_AGENT_MODEL=gpt-5.6-sol
SALES_AGENT_TIMEOUT_SECONDS=120
# Transport retries only; accepted range is 0-4. Business tool calls are never retried.
SALES_AGENT_PROVIDER_RETRIES=2
